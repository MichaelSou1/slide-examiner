      "bbox": {
        "x": 458.39,
        "y": 278.97,
        "width": 194.43,
        "height": 213.7
      },
      "text": "Incentives\n\nOpen Science Badge/Certification\n\nHigh profile prizes and challenges\n\nHigh profile awards in support of open science research",
      "style": {
        "font_size_pt": 11.0,
        "color": "#FFF2CC"
