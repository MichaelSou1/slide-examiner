      "bbox": {
        "x": 228.66,
        "y": 278.97,
        "width": 208.16,
        "height": 260.16
      },
      "text": "Capacity Sharing Resources\n\nOnline, free, Open Science curriculum on Open edX\n\nWorkshops, events, cohorts, science team meetings, hackathons\n\nMany paths to Open Science Badge",
      "style": {
        "font_size_pt": 11.0,
        "color": "#FFF2CC"
      },
