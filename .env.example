# Slide-Examiner large-model API configuration.
# Copy to .env for local use. Keep secrets out of git.
#
# Format note: keep comments on their own lines. The project has both a small
# Python .env loader and a few shell scripts that source .env directly.

# Shared OpenAI-compatible endpoint.
# Leave OPENAI_BASE_URL empty to use the OpenAI SDK default endpoint.
# For local vLLM, use a URL like http://127.0.0.1:8200/v1 and set the key to EMPTY
# if the server does not require authentication.
OPENAI_API_KEY=
OPENAI_BASE_URL=
PART3_API_STYLE=chat

# Reasoning/chat-template controls.
# PART3_DISABLE_THINKING is consumed by slide_examiner/api_config.py.
# PART3_CHAT_KWARGS is consumed by elicitation/eval scripts that forward raw
# OpenAI-compatible extra_body JSON. Leave it blank unless your endpoint supports it.
PART3_DISABLE_THINKING=0
PART3_CHAT_KWARGS=

# Role-specific services. Current code uses PART3_<ROLE>_* with ROLE in:
# GEN, OPTIMIZER, EXAMINER, JUDGE. Resolution falls back to OPENAI_* when a
# role-specific value is empty.

# GEN: frozen slide/deck generator.
PART3_GEN_MODEL=
PART3_GEN_BASE_URL=
PART3_GEN_API_KEY=
PART3_GEN_API_STYLE=

# OPTIMIZER: frozen reflection / skill-rewrite / revision model.
# In part3_run.py this falls back to GEN when unset.
PART3_OPTIMIZER_MODEL=
PART3_OPTIMIZER_BASE_URL=
PART3_OPTIMIZER_API_KEY=
PART3_OPTIMIZER_API_STYLE=

# EXAMINER: API-routed zero-shot examiner or critique model.
PART3_EXAMINER_MODEL=
PART3_EXAMINER_BASE_URL=
PART3_EXAMINER_API_KEY=
PART3_EXAMINER_API_STYLE=

# JUDGE: held-out final-eval judge, intentionally independent from examiner.
PART3_JUDGE_MODEL=
PART3_JUDGE_BASE_URL=
PART3_JUDGE_API_KEY=
PART3_JUDGE_API_STYLE=

# VLM: optional image-based examiner route used by scripts/part3_run.py
# when --examiner-vlm is passed.
PART3_VLM_MODEL=
PART3_VLM_BASE_URL=
PART3_VLM_API_KEY=
PART3_VLM_API_STYLE=

# External slide-agent drivers that reuse OpenAI-compatible large-model APIs.
# OPENAI_MODEL is a fallback used by scripts/part3_g7_gen_pptagent.py.
OPENAI_MODEL=
PPTAGENT_TEXT_MODEL=
PPTAGENT_VISION_MODEL=
